# The Remnant — Environment Variables
# Copy this file to .env.local and fill in your values

# Dev mode — bypasses Supabase auth, uses in-memory storage
# WARNING: Must be "false" or REMOVED for production/Vercel deployments.
# If set to "true" in production, the app will use a mock DB and no data persists.
NEXT_PUBLIC_DEV_MODE=true

# Supabase project credentials (from supabase.com dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
