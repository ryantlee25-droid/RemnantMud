# The Remnant — Environment Variables
# Copy this file to .env.local and fill in your values

# Set to "true" to bypass Supabase auth and use in-memory storage for local testing
# MUST be "false" or removed for production deployments
NEXT_PUBLIC_DEV_MODE=true

# Supabase project credentials (from supabase.com dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
