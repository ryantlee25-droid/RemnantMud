exports[`narratorVoice — act transition lines (deterministic) > act 1 → 2 transition 1`] = `
[
  {
    "text": "*"A voice not your own: The world shifts. Not the ground —*
*the ground was always unstable. The certainty.*
*The things you believed when you arrived have*
*rearranged, and their new shape is uncomfortable.*
*You are no longer a newcomer. You are a factor.*
*The factions have adjusted their calculations.*
*You are in the equation now, and equations*
*have a way of demanding solutions."*",
    "type": "echo",
  },
]
`;

exports[`narratorVoice — act transition lines (deterministic) > act 2 → 3 transition 1`] = `
[
  {
    "text": "*"A voice not your own: Something breaks. Not loud —*
*the opposite of loud. A quiet breaking, like a bone*
*fractured for years finally giving way.*
*The world has been holding its breath since MERIDIAN,*
*since the Collapse, since someone opened a door*
*that should have stayed closed.*
*The breath is running out.*
*What happens next happens to you.*
*There is no time to wonder if you are ready.*
*You are not ready. No one is. Go anyway."*",
    "type": "echo",
  },
]
`;

