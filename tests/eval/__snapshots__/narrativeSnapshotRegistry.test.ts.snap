exports[`deathProse — DEATH_PROSE_VARIANTS > variant: faction_execution 1`] = `
[
  {
    "text": "They knew your name. They wanted you to know that, before.",
    "type": "death",
  },
  {
    "text": "This was not random. This was a decision made in a room, by people who weighed the cost of letting you continue and decided the math didn't work in your favor. Someone signed something. Someone gave an order.",
    "type": "death",
  },
  {
    "text": "The world has opinions about you. You have made yourself legible to it. That is both the thing that got you killed and the thing that might eventually keep you alive.",
    "type": "death",
  },
  {
    "text": "CHARON-7 will rebuild you. The faction will still have your name on a list.",
    "type": "death",
  },
]
`;

exports[`deathProse — DEATH_PROSE_VARIANTS > variant: infection_hollow 1`] = `
[
  {
    "text": "You can hear yourself thinking. Soon you won't be able to.",
    "type": "death",
  },
  {
    "text": "The Hollow don't know they're the Hollow. That's the part nobody likes to say out loud. They're still in there, processing, moving through patterns that used to mean something. The hunger is just louder than everything else.",
    "type": "death",
  },
  {
    "text": "CHARON-7 is intercepting the turn. It doesn't do this out of mercy. It does this because what you were becoming was no longer useful to it.",
    "type": "death",
  },
  {
    "text": "You will wake up yourself. Mostly.",
    "type": "death",
  },
]
`;

