exports[`narratorVoice — pool content snapshots (deterministic) > PERSONAL_LOSS_WHISPERS pool — all IDs and texts 1`] = `
[
  {
    "id": "loss_001",
    "text": "*"A voice not your own: You will find what you*
*are looking for. You will wish you had not."*",
  },
  {
    "id": "loss_002",
    "text": "*"A voice not your own: The name you carry*
*weighs more than your pack."*",
  },
  {
    "id": "loss_003",
    "text": "*"A voice not your own: They would not recognize*
*what you have become. That is not a judgment."*",
  },
  {
    "id": "loss_004",
    "text": "*"A voice not your own: Somewhere in this world there*
*is proof of what happened to them."*",
  },
  {
    "id": "loss_005",
    "text": "*"A voice not your own: The grief you carry is not*
*a weakness. It is the only honest thing left."*",
  },
  {
    "id": "loss_006",
    "text": "*"A voice not your own: You are not looking for*
*them. You are looking for the version of you*
*that had them."*",
  },
  {
    "id": "loss_007",
    "text": "*"A voice not your own: They are not dead.*
*What happened to them is worse."*",
  },
  {
    "id": "loss_008",
    "text": "*"A voice not your own: Grief does not make you*
*soft. It makes you specific. That is useful here."*",
  },
  {
    "id": "loss_009",
    "text": "*"A voice not your own: The reason you came here*
*is still the reason. Do not let the world*
*replace it with a different reason."*",
  },
  {
    "id": "loss_010",
    "text": "*"A voice not your own: You are not ready for*
*what you will find. No one has ever been ready."*",
  },
  {
    "id": "loss_011",
    "text": "*"A voice not your own: The choice that led to their*
*loss was not yours. The choice you make now is."*",
  },
  {
    "id": "loss_012",
    "text": "*"A voice not your own: Carrying a loss this long*
*changes how the world looks. You see things others miss."*",
  },
]
`;

exports[`narratorVoice — pool content snapshots (deterministic) > PRESSURE_WHISPERS pool — all IDs and texts 1`] = `
[
  {
    "id": "pressure_001",
    "text": "*"A voice not your own: Your body knows something*
*your mind does not. Listen to your body."*",
  },
  {
    "id": "pressure_002",
    "text": "*"A voice not your own: The heartbeat you hear*
*is yours. Probably."*",
  },
  {
    "id": "pressure_003",
    "text": "*"A voice not your own: Run. Now. Do not look.*
*Do not think. Run."*",
  },
  {
    "id": "pressure_004",
    "text": "*"A voice not your own: It is closer than you think."*",
  },
  {
    "id": "pressure_005",
    "text": "*"A voice not your own: The next room is the wrong room.*
*You are going to enter it anyway."*",
  },
  {
    "id": "pressure_006",
    "text": "*"A voice not your own: The thing that is following you*
*knows you have noticed it. It does not care."*",
  },
  {
    "id": "pressure_007",
    "text": "*"A voice not your own: Your hands are shaking.*
*That is a signal, not a weakness. Receive it."*",
  },
  {
    "id": "pressure_008",
    "text": "*"A voice not your own: Stay still. Moving is*
*what gets them to notice you. Stay very still."*",
  },
  {
    "id": "pressure_009",
    "text": "*"A voice not your own: You have been in danger before.*
*This is a different kind."*",
  },
  {
    "id": "pressure_010",
    "text": "*"A voice not your own: The silence just changed.*
*Something entered it."*",
  },
  {
    "id": "pressure_011",
    "text": "*"A voice not your own: Everything you do now matters*
*more than everything you did before. Move carefully."*",
  },
  {
    "id": "pressure_012",
    "text": "*"A voice not your own: Fear is information.*
