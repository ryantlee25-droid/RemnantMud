exports[`hollowPressure — getPressureNarration > pressure level 5 1`] = `
[
  {
    "text": "The quality of the silence has changed. It has weight now.",
    "type": "narrative",
  },
  {
    "text": "Your footsteps sound too loud. Everything else sounds too quiet.",
    "type": "narrative",
  },
  {
    "text": "You count the shadows out of habit. One of them is wrong.",
    "type": "narrative",
  },
]
`;

exports[`hollowPressure — getPressureNarration > pressure level 6 1`] = `
[
  {
    "text": "Your heartbeat fills the silence. Every shadow has weight.",
    "type": "narrative",
  },
  {
    "text": "You realize you've been holding your breath. You don't remember starting.",
    "type": "narrative",
  },
  {
    "text": "The dark between things looks back.",
    "type": "narrative",
  },
]
`;

exports[`hollowPressure — getPressureNarration > pressure level 7 1`] = `
